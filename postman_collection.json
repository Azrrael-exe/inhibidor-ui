						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"azimuth\": 180.0,\n  \"elevation\": 45.0,\n  \"request_id\": \"abc123\"\n}",
							"options": {
								"raw": { "language": "json" }
							}
						},
						"url": {
							"raw": "{{base_url}}/set-navigation-and-power",
							"host": ["{{base_url}}"],
							"path": ["set-navigation-and-power"]
						}
					},
